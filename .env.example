# =====================================================================
# eVEGAH Rider — root .env template
# Copy this file to `.env` and fill in real values.
#
#   cp .env.example .env
#
# This file is committed; .env is gitignored. The API loads .env first,
# then server/.env, then server/.env.local (later wins).
# =====================================================================

PORT=5050
NODE_ENV=development

# ----------------------
# Database (local Docker Postgres from docker-compose.postgres.yml)
# ----------------------
DATABASE_URL=postgresql://evegah:evegah@127.0.0.1:5432/evegah
AUTO_MIGRATE=true

# ----------------------
# Auth (JWT + bcrypt). Required.
# ----------------------
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=8h

# Default users seeded on boot if missing. Idempotent per email —
# changing the password in the app is NEVER overwritten on restart.
SEED_ADMIN_EMAIL=adminev@gmail.com
SEED_ADMIN_PASSWORD=admin123
SEED_EMPLOYEE_EMAIL=user@gmail.com
SEED_EMPLOYEE_PASSWORD=user@123

# ----------------------
# Public URLs (used in receipts, callbacks, etc.)
# ----------------------
PUBLIC_BASE_URL=http://localhost:5174
PUBLIC_UPLOADS_PREFIX=/api/uploads
PUBLIC_WEB_ORIGIN=http://localhost:5174

# ----------------------
# ICICI UPI Payment Gateway (optional — set ENABLED=false to skip)
# ----------------------
VITE_ICICI_ENABLED=false
VITE_EVEGAH_UPI_ID=EVEGAH@icici

ICICI_MID=
ICICI_VPA=
ICICI_API_KEY=
ICICI_BASE_URL=https://apibankingone.icici.bank.in/api/MerchantAPI/UPI/v0
ICICI_QR_ENDPOINT=/QR3/
ICICI_TRANSACTION_STATUS_ENDPOINT=/TransactionStatus3/
ICICI_REFUND_ENDPOINT=/Refund/
ICICI_PUBLIC_KEY_PATH=./keys/icici_public_key.pem
ICICI_CLIENT_PRIVATE_KEY_P12_PATH=./keys/icici_privkey.pem
ICICI_CLIENT_PRIVATE_KEY_PASSPHRASE=
ICICI_SESSION_KEY_LENGTH=16
ICICI_ENCRYPTION_MODE=asymmetric
ICICI_TERMINAL_ID=5411
ICICI_PAYEE_NAME=Evegah

# ----------------------
# WhatsApp Cloud API (optional — for sending payment receipts)
# ----------------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_GRAPH_VERSION=21.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_TEMPLATE_NAME=rider_payment_receipt
WHATSAPP_TEMPLATE_LANGUAGE=en
WHATSAPP_TEMPLATE_BODY_PARAMS=name,invoice_no,invoice_date,plan,amount
WHATSAPP_TEMPLATE_PARAM_MODE=positional
WHATSAPP_TEMPLATE_INVOICE_DATE_FORMAT=DD/MM/YYYY
WHATSAPP_TEMPLATE_URL_BUTTON_INDEX=0
WHATSAPP_TEMPLATE_URL_BUTTON_VALUE_KEY=mediaurl

# ----------------------
# DigiLocker / APISetu (optional — for Aadhaar e-KYC)
# ----------------------
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_AUTHORIZE_URL=https://api.digitallocker.gov.in/public/oauth2/1/authorize
DIGILOCKER_TOKEN_URL=https://api.digitallocker.gov.in/public/oauth2/1/token
DIGILOCKER_REDIRECT_URI=http://localhost:5050/api/digilocker/callback
DIGILOCKER_DISABLE_OPENID=true
DIGILOCKER_TOKEN_AUTH_METHOD=body
DIGILOCKER_USE_PKCE=true
DIGILOCKER_USERINFO_URL=https://api.digitallocker.gov.in/public/oauth2/1/user
DIGILOCKER_AADHAAR_URL=https://api.digitallocker.gov.in/public/oauth2/3/xml/eaadhaar
DIGILOCKER_HTTP_TIMEOUT_MS=15000
DIGILOCKER_HTTP_RETRIES=1
DNS_RESULT_ORDER=ipv4first
