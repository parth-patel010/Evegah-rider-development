# =====================================================================
# eVEGAH Rider — server/.env template (optional)
#
# In most setups you only need the root .env. This file exists for cases
# where the API needs different values than the frontend (e.g. a server
# running in Docker that talks to a remote DB).
#
# Values here OVERRIDE the root .env when present. Anything not set here
# falls back to the root .env. Copy this to server/.env to use it:
#
#   cp server/.env.example server/.env
# =====================================================================

# Example: API-only DB override pointing at the docker-compose Postgres.
# DATABASE_URL=postgresql://evegah:evegah@127.0.0.1:5432/evegah
# JWT_SECRET=different-secret-for-server-only
